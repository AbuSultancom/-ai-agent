#!/usr/bin/env python3
"""
ai-config — Interactive configuration manager for AI Agent

Usage:
  ai-config              Interactive menu (all settings)
  ai-config --first-run  First-run wizard (only critical settings)
  ai-config get KEY      Print current value of KEY
  ai-config set KEY VAL  Set KEY=VAL in .env

Install (already done by install.sh):
  sudo cp scripts/ai-config /usr/local/bin/ai-config
  sudo chmod +x /usr/local/bin/ai-config
"""

import os
import re
import sys
import subprocess
import textwrap
from pathlib import Path
from typing import Optional

# ── Locate .env ───────────────────────────────────────────────────────────────
def find_env_file() -> Path:
    # Check AI_AGENT_DIR env var first
    if d := os.environ.get("AI_AGENT_DIR"):
        p = Path(d) / ".env"
        if p.exists():
            return p

    # Walk up from script location
    script_dir = Path(__file__).resolve().parent
    for candidate in [script_dir.parent, Path.home() / ".ai-agent", Path("/opt/ai-agent")]:
        p = candidate / ".env"
        if p.exists():
            return p

    # Last resort: current directory
    p = Path.cwd() / ".env"
    if p.exists():
        return p

    # No .env found — return the most likely location so caller can create it
    return script_dir.parent / ".env"


ENV_FILE = find_env_file()
EXAMPLE_FILE = ENV_FILE.parent / ".env.example"

# ── Colors ────────────────────────────────────────────────────────────────────
C = {
    "r": "\033[91m", "g": "\033[92m", "y": "\033[93m", "b": "\033[94m",
    "c": "\033[96m", "w": "\033[97m", "d": "\033[2m", "bold": "\033[1m",
    "reset": "\033[0m",
}

def c(text, *keys):
    return "".join(C.get(k, "") for k in keys) + text + C["reset"]


# ── .env read/write ───────────────────────────────────────────────────────────
def read_env() -> dict[str, str]:
    env: dict[str, str] = {}
    if not ENV_FILE.exists():
        return env
    for line in ENV_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            k, _, v = line.partition("=")
            # Strip inline comment
            v = re.sub(r"\s+#.*$", "", v).strip()
            env[k.strip()] = v
    return env


def write_env_key(key: str, value: str):
    """Update or append a key in .env."""
    if not ENV_FILE.exists():
        if EXAMPLE_FILE.exists():
            ENV_FILE.write_text(EXAMPLE_FILE.read_text())
        else:
            ENV_FILE.write_text("")

    text = ENV_FILE.read_text()
    pattern = re.compile(rf"^{re.escape(key)}\s*=.*$", re.MULTILINE)

    if pattern.search(text):
        text = pattern.sub(f"{key}={value}", text)
    else:
        text = text.rstrip("\n") + f"\n{key}={value}\n"

    ENV_FILE.write_text(text)


